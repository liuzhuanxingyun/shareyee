# Server
PORT=3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/shareyee?schema=public"

# Email (QQ SMTP)
MAIL_ENABLED=1
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your@qq.com
MAIL_PASS=your_smtp_auth_code
MAIL_FROM=your@qq.com
MAIL_TO=receiver@qq.com
MAIL_TEST_TOKEN=change_this_token

# Wallet (Moralis API)
WEB3_WALLET_ADDRESS=0x...
WEB3_CHAIN=bsc
MORALIS_API_KEY=your_moralis_api_key
WEB3_CACHE_TTL_MS=60000
