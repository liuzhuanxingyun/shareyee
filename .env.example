# Enable daily email job
MAIL_ENABLED=1

# QQ SMTP settings
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=@qq.com
MAIL_PASS=your_qq_smtp_auth_code
MAIL_FROM=@qq.com
MAIL_TO=@qq.com

# Token for manual test endpoint
MAIL_TEST_TOKEN=change_this_token

# Private portfolio data file path (optional)
PORTFOLIO_FILE=./data/portfolio.private.json

# Read-only wallet sync
WEB3_WALLET_ADDRESS=
WEB3_CHAIN=bsc
MORALIS_API_KEY=your_moralis_api_key

# Optional cache for wallet token snapshots (ms)
WEB3_CACHE_TTL_MS=60000
